# =============================================
# 環境変数テンプレート
# このファイルを .env にコピーしてローカルで使う
# ※ .env は絶対にGitにコミットしないこと！
# =============================================

# Claude API キー（https://console.anthropic.com で取得）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# ── X (Twitter) ──────────────────────────────
# 取得方法: README.md の「X API 取得手順」を参照
X_API_KEY=xxxxxxxxxx
X_API_SECRET=xxxxxxxxxx
X_ACCESS_TOKEN=xxxxxxxxxx-xxxxxxxxxx
X_ACCESS_SECRET=xxxxxxxxxx

# ── Instagram ────────────────────────────────
# Meta Developer > Instagram Graph API で取得
# ビジネスアカウント + Facebookページが必要
INSTAGRAM_USER_ID=xxxxxxxxxx
INSTAGRAM_ACCESS_TOKEN=xxxxxxxxxx

# ── GitHub（Instagram画像のraw URL生成に使用）──
# GitHub Actions では自動設定される
GITHUB_REPOSITORY=eternaldct-png/-

# ── TikTok（Content Posting API、審査後に利用可能）──
# TIKTOK_CLIENT_KEY=xxxxxxxxxx
# TIKTOK_CLIENT_SECRET=xxxxxxxxxx
# TIKTOK_ACCESS_TOKEN=xxxxxxxxxx
